# ─── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database (Supabase / PostgreSQL) ───────────────────────────────────────────
# Supabase: Settings > Database > Connection string (Transaction pooler)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres?pgbouncer=true
# Supabase direct connection (for migrations)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_minimum_32_chars_replace_me
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://kpr.band,https://www.kpr.band

# ─── Cloudinary ──────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=kpr_uploads

# ─── Midtrans ────────────────────────────────────────────────────────────────────
# Sandbox keys from https://dashboard.sandbox.midtrans.com/
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Email (Resend) ──────────────────────────────────────────────────────────────
# Get API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@kpr.band
EMAIL_BOOKING_TO=booking@kpr.band

# ─── Rate limiting ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_CONTACT=5
RATE_LIMIT_MAX_AUTH=10

# ─── Admin seed (only used for first seed run) ────────────────────────────────────
ADMIN_SEED_EMAIL=admin@kpr.band
ADMIN_SEED_PASSWORD=ChangeThisImmediately2024!
