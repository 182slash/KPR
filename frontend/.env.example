# ─── API ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── NextAuth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_replace_me

# ─── Cloudinary (public — read-only for Next.js Image component) ────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ─── Midtrans (client-side Snap.js) ─────────────────────────────────────────────
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# ─── Analytics (optional) ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Feature flags ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_MERCH_ENABLED=true
NEXT_PUBLIC_TICKETS_ENABLED=true
